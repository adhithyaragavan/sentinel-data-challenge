# --- Existing swarm (deep-dive stage) ---
NVIDIA_NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SLACK_WEBHOOK_URL=<your-slack-webhook-url>
RISK_SCORE_THRESHOLD=0.7

# --- Data intelligence pipeline (Cloud Storage + BigQuery) ---
# GCP project id created in infra/setup_gcp.md
GOOGLE_CLOUD_PROJECT=sentinel-data-challenge
# Cloud Storage bucket (landing zone for raw synthetic alerts)
GCS_BUCKET=sentinel-alerts-<your-suffix>
# BigQuery dataset + table for the raw alert warehouse
BQ_DATASET=sentinel
BQ_TABLE=alerts_raw
# Auth: on the T4 VM leave this UNSET and rely on the attached service
# account (Application Default Credentials). Only set a key path if you
# are running off-VM with a downloaded service-account key.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json
